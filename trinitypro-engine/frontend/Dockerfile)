# Stage 1: Install dependencies and build the Next.js application
FROM node:18-alpine AS builder

WORKDIR /app

COPY package.json yarn.lock ./
# Install dependencies, including dev dependencies for build
RUN yarn install --frozen-lockfile --production=false

COPY . .

# Build the Next.js application
# The `NEXT_PUBLIC_BACKEND_API_URL` is set at build time,
# but can also be overridden at runtime if it refers to a Docker network internal hostname.
# For production on AWS, you'll provide the actual backend URL here.
ARG NEXT_PUBLIC_BACKEND_API_URL
ENV NEXT_PUBLIC_BACKEND_API_URL=${NEXT_PUBLIC_BACKEND_API_URL}

RUN yarn build

# Stage 2: Run the production Next.js application
FROM node:18-alpine AS runner

WORKDIR /app

# Install only production dependencies
COPY --from=builder /app/package.json /app/yarn.lock ./
RUN yarn install --frozen-lockfile --production=true

# Copy Next.js build output
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/node_modules ./node_modules

# Ensure the entrypoint script is executable
RUN chmod +x ./.next/standalone/server.js

# Set environment variables for runtime (if they need to be dynamic)
# For Next.js, NEXT_PUBLIC_ vars are primarily build-time.
# Runtime variables are typically only used for SSR/API routes on the server side.
# Provide NEXT_PUBLIC_BACKEND_API_URL at runtime if your backend URL changes after build.
# ENV NEXT_PUBLIC_BACKEND_API_URL=http://your-backend-service-url:3000

EXPOSE 3000

# Start the Next.js production server
CMD ["node", ".next/standalone/server.js"]